<?xml version="1.0" encoding="UTF-8"?>
<bpws:process exitOnStandardFault="no" name="SampleProcess" suppressJoinFailure="yes"
    targetNamespace="http://xmlns.example.com/sample"
    xmlns:bpws="http://docs.oasis-open.org/wsbpel/2.0/process/executable"
    xmlns:tibex="http://www.tibco.com/bpel/2007/extensions"
    xmlns:sca-bpel="http://docs.oasis-open.org/ns/opencsa/sca-bpel/200801"
    xmlns:notation="http://www.eclipse.org/gmf/runtime/1.0.2/notation"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema"
    xmlns:bwext="http://www.tibco.com/bw/model/core/extensions">
  <tibex:Types>
    <xsd:schema targetNamespace="http://xmlns.example.com/sample/types">
      <xsd:element name="StartRequest" type="xsd:string"/>
      <xsd:element name="EndResponse" type="xsd:string"/>
    </xsd:schema>
  </tibex:Types>
  <tibex:ProcessInfo callable="false" createdBy="user" creationDate="2025-01-01T00:00:00Z"
      modifiedBy="user" modificationDate="2025-01-01T00:00:00Z" historySize="5" flowModel="BPEL"/>
  <tibex:ProcessInterface context="SampleContext" input="SampleInput" output="SampleOutput"/>
  <tibex:ProcessTemplateConfigurations/>
  <notation:Diagram type="ProcessDiagram"/>

  <bpws:import importType="http://www.w3.org/2001/XMLSchema" namespace="http://xmlns.example.com/sample/types" location="sample.xsd"/>

  <bpws:partnerLinks>
    <bpws:partnerLink name="SamplePartner" partnerLinkType="tns:SamplePartnerLinkType" myRole="client" partnerRole="service"/>
  </bpws:partnerLinks>

  <bpws:variables>
    <bpws:variable name="Start" element="tns:StartRequest" sca-bpel:internal="true" tibex:parameter="in"/>
    <bpws:variable name="End-input" element="tns:EndResponse" sca-bpel:internal="true"/>
    <bpws:variable name="ConstantValue" type="xsd:string" sca-bpel:hotUpdate="false">
      <bpws:from>
        <bpws:literal>Hello BW6</bpws:literal>
      </bpws:from>
    </bpws:variable>
  </bpws:variables>

  <bpws:extensions/>

  <bpws:scope name="scope">
    <bpws:flow name="flow">
      <bpws:links>
        <bpws:link name="StartToMiddle" tibex:linkType="SUCCESS"/>
        <bpws:link name="MiddleToEnd" tibex:linkType="SUCCESSWITHCONDITION" tibex:label="continue"/>
      </bpws:links>

      <bpws:extensionActivity>
        <tibex:receiveEvent createInstance="yes" eventTimeout="0" name="Start"
            tibex:xpdlId="start-uuid" variable="Start">
          <bpws:sources>
            <bpws:source linkName="StartToMiddle">
              <bpws:transitionCondition>true()</bpws:transitionCondition>
            </bpws:source>
          </bpws:sources>
          <tibex:eventSource>
            <tibex:StartEvent/>
          </tibex:eventSource>
        </tibex:receiveEvent>
      </bpws:extensionActivity>

      <bpws:empty name="OnMessageStart" tibex:constructor="onMessageStart" tibex:xpdlId="middle-uuid">
        <bpws:targets>
          <bpws:target linkName="StartToMiddle"/>
        </bpws:targets>
        <bpws:sources>
          <bpws:source linkName="MiddleToEnd"/>
        </bpws:sources>
      </bpws:empty>

      <bpws:extensionActivity>
        <tibex:activityExtension inputVariable="End-input" name="End" tibex:xpdlId="end-uuid">
          <bpws:targets>
            <bpws:target linkName="MiddleToEnd"/>
          </bpws:targets>
          <tibex:inputBindings>
            <tibex:inputBinding expression="concat('done-', $ConstantValue)" expressionLanguage="urn:tibco:xslt:1.0"/>
          </tibex:inputBindings>
          <tibex:config>
            <bwext:BWActivity activityTypeID="com.tibco.plugin.sample.end"/>
          </tibex:config>
        </tibex:activityExtension>
      </bpws:extensionActivity>
    </bpws:flow>
  </bpws:scope>
</bpws:process>
